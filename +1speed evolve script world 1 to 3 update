    TrackCorner.Parent = SwitchTrack
    
    local TrackStroke = Instance.new("UIStroke")
    TrackStroke.Color = Theme.Border
    TrackStroke.Thickness = 1
    TrackStroke.Parent = SwitchTrack

    local SwitchKnob = Instance.new("Frame")
    SwitchKnob.Size = UDim2.new(0, 16, 0, 16)
    SwitchKnob.Position = UDim2.new(0, 3, 0, 3)
    SwitchKnob.BackgroundColor3 = Theme.TextDark
    SwitchKnob.Parent = SwitchTrack

    local KnobCorner = Instance.new("UICorner")
    KnobCorner.CornerRadius = UDim.new(1, 0)
    KnobCorner.Parent = SwitchKnob

    SwitchTrack.MouseButton1Click:Connect(function()
        Flags[flagName] = not Flags[flagName]
        if Flags[flagName] then
            TweenService:Create(SwitchTrack, Fast_Info, {BackgroundColor3 = Theme.ToggleBgOn}):Play()
            TweenService:Create(TrackStroke, Fast_Info, {Color = Theme.Green}):Play()
            TweenService:Create(SwitchKnob, Fast_Info, {Position = UDim2.new(1, -19, 0, 3), BackgroundColor3 = Theme.Green}):Play()
            if onCallback then task.spawn(onCallback) end
        else
            TweenService:Create(SwitchTrack, Fast_Info, {BackgroundColor3 = Theme.ToggleBgOff}):Play()
            TweenService:Create(TrackStroke, Fast_Info, {Color = Theme.Border}):Play()
            TweenService:Create(SwitchKnob, Fast_Info, {Position = UDim2.new(0, 3, 0, 3), BackgroundColor3 = Theme.TextDark}):Play()
            if offCallback then task.spawn(offCallback) end
        end
    end)
end

