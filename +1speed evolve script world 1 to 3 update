        local rootPart = character:WaitForChild("HumanoidRootPart", 3)
        if rootPart then rootPart.CFrame = targetCFrame end -- Uses the dynamically matched CFrame
        task.wait(0.05)
    end
end)

createFeatureRow("Auto Evolve Status", "AutoEvolve", function()
    local args = { { Action = "Evolve" } }
    while Flags.AutoEvolve do
        EvolveRemote:FireServer(unpack(args))
        task.wait(0.25)
    end
end)

createFeatureRow("Instant Speed", "SuperSpeed", function()
    while Flags.SuperSpeed do
        for i = 1, 20 do AddSpeedRemote:FireServer() end
